# ===========================
# DisasterLink .gitignore
# ===========================

# ===========================
# Backend (Java / Maven)
# ===========================

# Compiled class files
backend/target/
backend/*.class

# Maven
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# Logs
*.log
logs/

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.classpath
.project
.settings/
bin/

# VS Code Java
.vscode/
*.code-workspace

# Spring Boot
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-prod.properties

# ===========================
# Frontend (React / Node)
# ===========================

frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# npm / yarn
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ===========================
# Environment & Secrets
# (NEVER commit these)
# ===========================

.env
.env.*
!.env.example

# Credentials
secrets/
*.pem
*.key
*.p12
*.jks

# ===========================
# Docker
# ===========================

# Don't ignore docker-compose.yml (it's config, not secrets)
# But ignore override files with real credentials
docker-compose.override.yml
docker-compose.prod.yml

# ===========================
# OS Files
# ===========================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ===========================
# Misc
# ===========================

# Test coverage reports
backend/target/site/
coverage/

# Temp files
*.tmp
*.swp
*.bak
